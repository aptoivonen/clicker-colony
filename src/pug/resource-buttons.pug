- 
  const resourceBlocks = [
      { name: "CyberCoins", icon: "bi-cash-stack" },
      { name: "Power", icon: "bi-lightning-fill" },
    ]

mixin resourceBlock(name, icon)
  .col-12
    .input-group
      label.col-10.input-group-text 
        i.bi(class='' + icon)
        span.ms-2 #{name}
      button.col-2.btn.btn-outline-secondary
        i.bi.bi-plus-square-fill(style='color: green;')

.container 
  .row.gx-2.gy-3
    each block in resourceBlocks
      +resourceBlock(block.name, block.icon)